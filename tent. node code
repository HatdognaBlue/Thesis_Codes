const express = require('express');
const http = require('http');
const { Server } = require('socket.io');
const sql = require('mssql');
const cors = require('cors');

const app = express();
const server = http.createServer(app);
const io = new Server(server, { cors: { origin: "*" } });

app.use(cors());
app.use(express.json());

// --- DATABASE CONFIGURATION ---
const dbConfig = {
    user: '', // Leave blank if using Windows Auth (adjust as needed)
    password: '',
    server: 'localhost', 
    database: 'YourDatabaseName',
    options: { encrypt: false, trustServerCertificate: true }
};

// --- GLOBAL STATE ---
let scores = {}; // { "Name": Score }
let gameState = {
    isActive: false,
    currentQuestionIndex: 0,
    questions: [
        { text: "What is 5 + 5?", options: ["8", "10", "12", "15"], correct: "B" },
        { text: "Which language is used for Flutter?", options: ["Java", "Dart", "Python", "C++"], correct: "B" }
    ]
};

// --- CORE LOGIC ---
io.on('connection', (socket) => {
    console.log('User connected:', socket.id);

    // [QUIZ] Student Joins
    socket.on('join_game', (studentName) => {
        scores[studentName] = 0;
        console.log(`${studentName} joined the lobby.`);
    });

    // [QUIZ] Professor Starts or moves to Next
    socket.on('start_quiz_signal', () => {
        gameState.isActive = true;
        sendQuestion();
    });

    // [QUIZ] Handle Student Answer
    socket.on('submit_answer', (data) => {
        // data = { name: "Christopher", isCorrect: true }
        if (data.isCorrect) {
            scores[data.name] = (scores[data.name] || 0) + 100;
        }
        // Broadcast updated leaderboard to everyone immediately
        io.emit('update_leaderboard', getSortedLeaderboard());
    });

    // [RECITATION] Random Student Picker
    socket.on('trigger_random_recitation', async () => {
        try {
            let pool = await sql.connect(dbConfig);
            let result = await pool.request().query(`
                SELECT TOP 1 StudentName FROM Attendance 
                WHERE Status = 'Present' AND CAST(Date AS DATE) = CAST(GETDATE() AS DATE)
                ORDER BY NEWID()
            `);

            if (result.recordset.length > 0) {
                const picked = result.recordset[0].StudentName;
                console.log("Recitation Picked:", picked);
                // Send alert to ALL phones
                io.emit('recitation_alert', { 
                    selected_student: picked,
                    message: "Please stand up for recitation!" 
                });
            }
        } catch (err) {
            console.error("SQL Error during recitation:", err);
        }
    });

    function sendQuestion() {
        if (gameState.currentQuestionIndex < gameState.questions.length) {
            const q = gameState.questions[gameState.currentQuestionIndex];
            io.emit('new_question', {
                text: q.text,
                options: q.options,
                correct_answer: q.correct
            });
            gameState.currentQuestionIndex++;
        } else {
            // End of game: Send Top 3 winners
            const finalPodium = getSortedLeaderboard().slice(0, 3);
            io.emit('quiz_over', { winners: finalPodium });
            gameState.isActive = false;
        }
    }

    function getSortedLeaderboard() {
        return Object.entries(scores)
            .map(([name, score]) => ({ name, score }))
            .sort((a, b) => b.score - a.score);
    }
});

const PORT = 5000;
server.listen(PORT, '0.0.0.0', () => {
    console.log(`Backend Active: http://192.168.137.1:${PORT}`);
});
